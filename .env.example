# Copy this file to server/.env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/logistics_tracker

# Or use individual fields:
# DB_PASSWORD=postgres

# JWT secret — change this to a long random string in production
JWT_SECRET=changeme_use_a_long_random_secret_here

# Server port
PORT=3001

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
