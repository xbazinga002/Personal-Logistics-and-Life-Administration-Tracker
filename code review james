#### Comment #4 — `[MEDIUM]`
**Location:** `server/src/middleware/validate.ts` — `validateCreateItem()`

**Issue:** The input validation middleware manually checks each field with nested if-else blocks. The `due_date` format check uses a regex that does not account for timezone-aware ISO strings — a client sending `2026-04-01T00:00:00+05:30` is incorrectly rejected while `2026-04-01T00:00:00Z` passes. Validation logic is duplicated between `validateCreateItem` and `validateUpdateItem`.

**Suggestion:** Replace the manual validation with a Zod schema. `z.coerce.date()` handles all valid ISO 8601 formats correctly. Shared field schemas can be defined once and composed into both create and update schemas, eliminating duplication.

```ts
// validate.ts (after)
import { z } from 'zod';

const itemFields = {
  title:           z.string().min(1).max(255),
  due_date:        z.coerce.date().optional(),
  category_id:     z.number().int().positive().optional(),
  recurrence_rule: z.enum(['weekly', 'monthly', 'yearly']).optional(),
  status:          z.enum(['pending', 'completed', 'snoozed']).optional(),
};

const createItemSchema = z.object({ ...itemFields, title: itemFields.title });
const updateItemSchema = z.object(itemFields).partial().refine(
  (data) => Object.keys(data).length > 0,
  { message: 'At least one field is required' }
);

export function validateCreateItem(req: Request, res: Response, next: NextFunction) {
  const result = createItemSchema.safeParse(req.body);
  if (!result.success) return res.status(400).json(result.error);
  return next();
}
```

