#### Comment #2 — `[HIGH]`
**Location:** `server/src/controllers/itemController.ts` — `deleteItem()`, `updateItem()`

**Issue:** Neither the `deleteItem` nor `updateItem` handler verifies item ownership before executing. The repository receives the item ID from the URL parameter and acts on it directly. Any authenticated user who can guess or discover another user's item ID — which is a sequential integer and therefore trivially enumerable — can delete or overwrite that item. This is an Insecure Direct Object Reference (IDOR) vulnerability.

**Suggestion:** Scope the repository queries to include `user_id` so that a non-matching owner results in zero rows affected, returning a 404.

```ts
// itemRepository.ts — deleteItem (before)
export async function deleteItem(id: number): Promise<void> {
  await knex('items').where({ id }).delete();
  // No user_id check — any authenticated user can delete any item
}

// itemRepository.ts — deleteItem (after)
export async function deleteItem(id: number, userId: number): Promise<boolean> {
  const count = await knex('items')
    .where({ id, user_id: userId }) // scoped to owner
    .delete();
  return count > 0;
}

// itemController.ts — deleteItem (after)
export async function deleteItem(req: Request, res: Response) {
  const userId = req.user!.id;
  const deleted = await itemService.deleteItem(Number(req.params.id), userId);
  if (!deleted) return res.status(404).json({ error: 'Item not found' });
  return res.status(204).send();
}
```

